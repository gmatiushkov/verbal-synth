      "descriptions": [
        {
          "style": "functional",
          "text": "Чистый суббас для трэпа и хип-хопа, держит низ микса без грязи и обертонов"
        },
        {
          "style": "instrument",
          "text": "Как глубокая нота контрабаса смычком в самом нижнем регистре, почти без призвука"
        },
        {
          "style": "psychoacoustic",
          "text": "Глубокий, суббасовый, тёмный, очень чистый, мягкая атака, тёплое аналоговое тело, статичный"
        },
        {
          "style": "emotional",
          "text": "Спокойная уверенная опора, ощущение тяжести и тишины под всем остальным"
        },
        {
          "style": "metaphor",
          "text": "Дрожь земли под ногами в пустом бетонном зале"
        },
        {
          "style": "telegraphic",
          "text": "Чистый тёплый суббас"
        }
      ],
      "flags": [
        "описание обещает мягкую/плавную атаку, но amp_attack 0.05 резкий (<~40мс)"
      ]
    },
