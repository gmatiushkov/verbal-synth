      "descriptions": [
        {
          "style": "functional",
          "text": "Acid-бас для эйсид-хауса и техно, щёлкающий резонансный сквелч с движением огибающей фильтра"
        },
        {
          "style": "instrument",
          "text": "Классический 303-звук: квадратная волна сквозь самовозбуждающийся резонансный фильтр"
        },
        {
          "style": "psychoacoustic",
          "text": "Резкий, пронзительный, кислотный, свистящий резонанс, мгновенная атака, спадающий вниз 'вау', перегретое тело"
        },
        {
          "style": "emotional",
          "text": "Дерзкий, гипнотичный и нахальный, тянет в транс на танцполе"
        },
        {
          "style": "metaphor",
          "text": "Резиновый шланг, хлещущий по неоновой воде"
        },
        {
          "style": "telegraphic",
          "text": "Резонансный кислотный сквелч"
        }
      ],
      "flags": [
        "фильтр-свип: высокий резонанс+fenv, но fenv_decay 0.35 короткий — будет щелчок вместо свипа"
