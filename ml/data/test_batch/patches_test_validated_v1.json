        "reverb_damp": 0.5,
        "reverb_mix": 0.22
      },
      "descriptions": [
        {
          "style": "functional",
          "text": "Щипковый аккомпанемент для акустической баллады или интро — мягкие арпеджио в среднем регистре"
        },
        {
          "style": "instrument",
          "text": "Как классическая гитара с нейлоновыми струнами, тёплый щипок пальцами у розетки"
        },
        {
          "style": "psychoacoustic",
          "text": "Тёплый, прозрачный, мягкая струнная окраска, мгновенная атака с быстрым спадом и коротким хвостом, чистый сигнал"
        },
        {
          "style": "emotional",
          "text": "Уютное, спокойное, чуть ностальгическое — как тихий вечер дома"
        },
        {
          "style": "metaphor",
          "text": "Капли воды на тёплом дереве в полумраке комнаты"
        },
        {
          "style": "telegraphic",
          "text": "Тёплый нейлоновый щипок"
        }
      ],
      "flags": [
        "sustain 0.05: для щипкового звука обычно либо 0 (затухает), либо высокий",
        "описание обещает мягкую/плавную атаку, но amp_attack 0.00 резкий (<~40мс)"
      ]
    },
    {
